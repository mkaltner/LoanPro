<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <gradient android:startColor="#ffb1b5b8" android:endColor="#ff515254" android:angle="90.0" />
            <stroke android:width="1.0dip" android:color="#ff000000" />
        </shape>
    </item>
    <item android:state_focused="true">
        <shape>
            <gradient android:startColor="#ffb1b5b8" android:endColor="#ff515254" android:angle="270.0" />
            <stroke android:width="1.0dip" android:color="#ffffffff" />
        </shape>
    </item>
    <item>
        <shape>
            <gradient android:startColor="#ffb1b5b8" android:endColor="#ff515254" android:angle="270.0" />
            <stroke android:width="0.5dip" android:color="#ff000000" />
        </shape>
    </item>
</selector>
